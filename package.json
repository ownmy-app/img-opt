{
  "name": "@nometria-ai/img-opt",
  "version": "2.1.1",
  "description": "Auto-scan, download, compress (WebP + WebM), and rewrite image & video URLs. Zero config.",
  "type": "module",
  "bin": {
    "img-opt": "./src/cli.js"
  },
  "exports": {
    ".": "./src/run-all.js",
    "./download": "./src/download.js",
    "./compress": "./src/compress.js",
    "./replace": "./src/replace.js",
    "./scan": "./src/scan.js",
    "./video-compress": "./src/video-compress.js"
  },
  "files": [
    "src/",
    "image-assets.config.example.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "prepublishOnly": "npm test",
    "images": "node src/run-all.js",
    "images:scan": "node src/scan.js",
    "images:download": "node src/download.js",
    "images:compress": "node src/compress.js",
    "images:video": "node src/video-compress.js",
    "images:replace": "node src/replace.js"
  },
  "keywords": [
    "images",
    "video",
    "webp",
    "webm",
    "optimize",
    "compress",
    "sharp",
    "ffmpeg",
    "auto-scan",
    "vite",
    "nextjs",
    "astro",
    "performance",
    "image-optimization",
    "video-optimization",
    "cli",
    "download",
    "devtools"
  ],
  "license": "MIT",
  "author": "Nometria <hello@nometria.com>",
  "homepage": "https://github.com/nometria/img-opt#readme",
  "bugs": {
    "url": "https://github.com/nometria/img-opt/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nometria/img-opt.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "sharp": ">=0.32.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
